# Python
__pycache__/
*.py[codz]
*$py.class
*.egg-info/
*.egg
build/
dist/

# Virtual environments
.venv/
venv/
env/

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store

# Data — never commit downloaded files or processed outputs
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Build artifacts
plots/
outputs/*.html
*.log

# Run logs (auto-generated, not deliverables)
logs/runs/

# Environment / secrets
.env
.env.local

# Notebooks
.ipynb_checkpoints/

# Node (docx builder — root level)
/node_modules/
/package.json
/package-lock.json

# Web app
web/node_modules/
web/.next/
web/.env.local

# Word temp files
~$*.docx
reports/unpacked/

# Note: uv.lock IS committed for reproducibility — do not ignore it.
.claude/
